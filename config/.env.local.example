# =============================================================================
# MinIO Config
# =============================================================================
MINIO_ROOT_NAME="minio_admin"
MINIO_ROOT_PASSWORD="changeme"
MINIO_USER_NAME="minio_user"
MINIO_USER_PASSWORD="changeme"
MINIO_USER_BUCKET_NAME="ensam3d-data"
MINIO_USER_POLICY_NAME="ensam3d-bucket-policy"
MINIO_HOST="127.0.0.1"
MINIO_INTERNAL_PORT=9000
MINIO_EXTERNAL_PORT=9000
MINIO_PORT=${MINIO_EXTERNAL_PORT}
INIT_MINIO_HOST="minio-server"


# =============================================================================
# PostgreSQL Config
# =============================================================================
POSTGRES_SUPERUSER_NAME="postgres_admin"
POSTGRES_SUPERUSER_PASSWORD="changeme"
POSTGRES_SYSTEM_DB_NAME="postgres_db"
POSTGRES_USER_NAME="postgres_user"
POSTGRES_USER_PASSWORD="changeme"
POSTGRES_USER_DB_NAME="user_db"
POSTGRES_HOST="127.0.0.1"
POSTGRES_INTERNAL_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_PORT=${POSTGRES_EXTERNAL_PORT}


# =============================================================================
# Redis Config
# =============================================================================
REDIS_ADMIN_NAME="redis_admin"
REDIS_ADMIN_PASSWORD="changeme"
REDIS_USER_NAME="redis_user"
REDIS_USER_PASSWORD="changeme"
REDIS_HOST="127.0.0.1"
REDIS_INTERNAL_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_PORT=${REDIS_EXTERNAL_PORT}


# =============================================================================
# Celery Config
# =============================================================================
CELERY_BROKER_DB_INDEX=0
CELERY_RESULT_DB_INDEX=1
CELERY_APP_NAME="ensam3d-backend"
CELERY_RESULT_EXPIRES=60
CELERY_QUEUE_NAME_INFERENCE="ensam3d"
CELERY_QUEUE_NAME_DEFAULT="default"
CELERY_EXCHANGE_NAME="tasks"


# =============================================================================
# Server Config
# =============================================================================
SERVER_HOST="0.0.0.0"
SERVER_PORT=8000
SERVER_LOG_LEVEL="INFO"
SERVER_TITLE="Human Pose Estimation Service"
SERVER_DESCRIPTION="Production-oriented REST API service exposing ensam3d_inference as a managed backend for distributed 3D human pose estimation, with video ingestion, GPU worker orchestration, annotated visualization rendering, and persistent artifact storage."
SERVER_VERSION="0.1.0"
SERVER_DOCS_URL="/docs"
SERVER_REDOC_URL="/redoc"
SERVER_OPENSERVER_URL="/openapi.json"
SERVER_DEEP_HEALTH_TIMEOUT=3.0


# =============================================================================
# Worker Config
# =============================================================================
WORKER_INFERENCE_LOGLEVEL="INFO"
WORKER_INFERENCE_MODEL_PATH="sam-3d-body-vith"
WORKER_INFERENCE_MODEL_DEVICE="cuda"
WORKER_INFERENCE_DETECTOR_DEVICE="cuda"
WORKER_INFERENCE_DETECTOR_MODEL_PATH="yolo26n.pt"

WORKER_DEFAULT_LOGLEVEL="INFO"
WORKER_DEFAULT_POOL="prefork"
WORKER_DEFAULT_CONCURRENCY=4
WORKER_DEFAULT_PREFETCH_MULTIPLIER=1